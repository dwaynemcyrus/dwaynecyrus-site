---
import { siteConfig } from "../config/site";

const socialLinks = [
  { label: "X", href: siteConfig.xUrl },
  { label: "YouTube", href: siteConfig.youtubeUrl },
  { label: "Substack", href: siteConfig.substackUrl },
].filter((link) => link.href);

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner container">
    <p class="footer-copyright">
      © {currentYear}{" "}{siteConfig.businessName}.
    </p>
    {
      socialLinks.length > 0 && (
        <ul class="social-links" aria-label="Social profiles">
          {socialLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      )
    }
    <ul class="footer-links" aria-label="Footer navigation">
      <li><a href="/">Home</a></li>
      <li><a href="/scorecard">Scorecard</a></li>
      <li><a href="/privacy">Privacy Policy</a></li>
      <li><a href="/legal">Legal Notice</a></li>
    </ul>
  </div>
</footer>
