---
import { siteConfig } from "../config/site";

interface Props {
  id: string;
}

const { id } = Astro.props;
const manId = `${id}-man`;
const womanId = `${id}-woman`;
const firstNameId = `${id}-first-name`;
const lastNameId = `${id}-last-name`;
const emailId = `${id}-email`;
---

<div class="newsletter-form-wrap">
  <form
    action={siteConfig.buttondownFormAction}
    method="post"
    class="embeddable-buttondown-form newsletter-form"
    aria-describedby={`${id}-consent ${id}-status`}
  >
    <fieldset>
      <legend>Which best describes you?</legend>

      <div class="choice-list">
        <div class="choice">
          <input
            type="radio"
            name="metadata__gender"
            id={manId}
            value="man"
            required
          />
          <label for={manId}>I am a man carrying silent weight.</label>
        </div>

        <div class="choice">
          <input
            type="radio"
            name="metadata__gender"
            id={womanId}
            value="woman"
            required
          />
          <label for={womanId}
            >I am a woman standing with men who carry silent weight.</label
          >
        </div>
      </div>
    </fieldset>

    <fieldset>
      <legend>Contact Details</legend>

      <div class="contact-fields">
        <div class="field">
          <label for={firstNameId}>First Name</label>
          <input
            type="text"
            name="metadata__first_name"
            id={firstNameId}
            autocomplete="given-name"
            required
          />
        </div>

        <div class="field">
          <label for={lastNameId}>Last Name</label>
          <input
            type="text"
            name="metadata__last_name"
            id={lastNameId}
            autocomplete="family-name"
            required
          />
        </div>

        <div class="field email-field">
          <label for={emailId}>Enter your email</label>
          <input
            type="email"
            name="email"
            id={emailId}
            autocomplete="email"
            inputmode="email"
            required
          />
        </div>
      </div>
    </fieldset>

    <input
      class="button submit-button"
      type="submit"
      value="Subscribe me to the Letters"
    />
  </form>

  <p id={`${id}-consent`} class="consent">
    By subscribing, you agree to receive Letters from Cyrus two to three times
    each week. Unsubscribe at any time. <a href="/privacy"
      >Read the Privacy Policy.</a
    >
  </p>
  <p id={`${id}-status`} class="form-status">
    Your subscription is handled by Buttondown.
  </p>
</div>

<script>
  const subscriberTags = {
    woman: "sub_tag_44xcvqncep9mm890nrr7skdczv",
    man: "sub_tag_7pzyd0fh9q8jfscxt76vkfzseg",
  } as const;

  for (const form of document.querySelectorAll<HTMLFormElement>(
    ".embeddable-buttondown-form",
  )) {
    form.addEventListener("submit", () => {
      const gender = form.querySelector<HTMLInputElement>(
        'input[name="metadata__gender"]:checked',
      );
      if (!gender || !(gender.value in subscriberTags)) return;

      let hidden = form.querySelector<HTMLInputElement>('input[name="tag"]');
      if (!hidden) {
        hidden = document.createElement("input");
        hidden.type = "hidden";
        hidden.name = "tag";
        form.appendChild(hidden);
      }

      hidden.value =
        subscriberTags[gender.value as keyof typeof subscriberTags];
    });
  }
</script>

<style>
  .newsletter-form-wrap {
    max-width: 46rem;
  }

  .newsletter-form,
  fieldset,
  .contact-fields,
  .field,
  .choice-list {
    display: grid;
  }

  .newsletter-form {
    gap: var(--space-5);
  }

  fieldset {
    gap: var(--space-3);
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  legend {
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 500;
    line-height: 1.2;
  }

  .choice-list,
  .contact-fields {
    gap: var(--space-3);
  }

  .choice {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2);
    align-items: start;
  }

  .choice input {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.32rem;
    accent-color: var(--color-ink);
  }

  .field {
    gap: var(--space-1);
  }

  label {
    font-size: var(--step--1);
    font-weight: 750;
  }

  .field input {
    width: 100%;
    min-height: 2.75rem;
    padding: 0.72rem 0.85rem;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius);
    background: var(--color-paper);
  }

  .submit-button {
    justify-self: start;
    cursor: pointer;
  }

  .consent,
  .form-status {
    margin-block: var(--space-3) 0;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .form-status {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (min-width: 42rem) {
    .contact-fields {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .email-field {
      grid-column: 1 / -1;
    }
  }
</style>
