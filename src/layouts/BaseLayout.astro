---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { siteConfig } from "../config/site";
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  robots?: string;
}

const { title, description, canonicalPath, robots } = Astro.props;
const canonicalUrl = siteConfig.siteUrl
  ? new URL(canonicalPath, siteConfig.siteUrl).toString()
  : undefined;
const structuredData = siteConfig.siteUrl
  ? {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${siteConfig.siteUrl}/#website`,
          url: siteConfig.siteUrl,
          name: siteConfig.siteName,
          description,
          publisher: { "@id": `${siteConfig.siteUrl}/#person` },
        },
        {
          "@type": "Person",
          "@id": `${siteConfig.siteUrl}/#person`,
          name: siteConfig.authorName,
          url: siteConfig.siteUrl,
        },
      ],
    }
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {
      structuredData && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      )
    }
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader />
    <main id="main-content" class="site-main">
      <slot />
    </main>
    <SiteFooter />
    <SpeedInsights />
  </body>
</html>
