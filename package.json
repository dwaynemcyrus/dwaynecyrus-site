{
  "name": "letters-from-cyrus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write \"**/*.{astro,css,js,json,mjs,ts}\"",
    "format:check": "prettier --check \"**/*.{astro,css,js,json,mjs,ts}\"",
    "lint": "eslint .",
    "check": "astro check",
    "test": "node --test"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "1.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
